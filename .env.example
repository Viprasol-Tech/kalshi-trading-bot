# Kalshi Trading Bot — environment configuration
# Copy this file to `.env` and fill in your values. NEVER commit `.env`.

# --- Credentials -------------------------------------------------------------
# Your Kalshi API key ID (UUID) from Profile -> API Keys.
KALSHI_API_KEY_ID=

# Path to your RSA private key PEM file (downloaded once on key creation).
# Keep this file outside version control (the ./secrets/ dir is git-ignored).
KALSHI_PRIVATE_KEY_PATH=./secrets/kalshi_private_key.pem

# --- Environment -------------------------------------------------------------
# 'demo' = sandbox (recommended for testing), 'prod' = live trading.
KALSHI_ENVIRONMENT=demo

# --- Safety ------------------------------------------------------------------
# When true, orders are simulated and never sent to Kalshi. Keep this ON until
# you fully understand your strategy.
KALSHI_DRY_RUN=true

# HTTP request timeout (seconds).
KALSHI_REQUEST_TIMEOUT=10
